# SHA-256 digest of the shared project password (lowercase hex, no spaces).
# Used by the client-side gate on project pages (e.g. Set Dojo). Not secret storage.
#
# Generate (POSIX shell):
#   echo -n 'your-password' | openssl dgst -sha256
# Copy the hex line only (lowercase).
#
# Leave unset to disable the gate during local development.
PUBLIC_PROJECT_ACCESS_SHA256=
