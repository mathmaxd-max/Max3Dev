---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="max3.dev" description="max3.dev — kleine Projekte und Experimente.">
  <main class="home">
    <section class="home__hero">
      <p class="home__eyebrow">Experiments · Games · Tools</p>
      <h1>max3.dev</h1>
      <p class="home__lead">
        Eine schlanke Homepage für kleine Ideen — gehostet über Cloudflare, gebaut mit Astro.
      </p>
      <nav class="home__links" aria-label="Projekte">
        <a class="home__project" href="/set_dojo/">Set Dojo</a>
      </nav>
    </section>
  </main>
</BaseLayout>

<style>
  .home {
    width: min(720px, calc(100vw - 2rem));
    margin: 0 auto;
    padding: 4rem 0 3rem;
  }

  .home__hero {
    background: rgba(17, 24, 39, 0.82);
    border: 1px solid rgba(148, 163, 184, 0.18);
    border-radius: 24px;
    padding: 2rem;
    box-shadow: 0 24px 64px rgba(3, 7, 18, 0.45);
    backdrop-filter: blur(16px);
  }

  .home__eyebrow {
    margin: 0 0 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.76rem;
    font-weight: 700;
    color: #94a3b8;
  }

  h1 {
    margin: 0 0 0.75rem;
    font-size: clamp(2.4rem, 6vw, 3.4rem);
    line-height: 1.05;
    color: #f8fafc;
  }

  .home__lead {
    margin: 0 0 1.75rem;
    color: #cbd5e1;
    line-height: 1.55;
    font-size: 1.05rem;
  }

  .home__links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .home__project {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.85rem 1.25rem;
    border-radius: 999px;
    background: linear-gradient(135deg, rgba(59, 130, 246, 0.94), rgba(16, 185, 129, 0.94));
    color: #ffffff;
    font-weight: 700;
    text-decoration: none;
    box-shadow: 0 12px 24px rgba(14, 165, 233, 0.22);
    transition:
      transform 180ms ease,
      box-shadow 180ms ease;
  }

  .home__project:hover,
  .home__project:focus-visible {
    transform: translateY(-1px);
    box-shadow: 0 16px 28px rgba(14, 165, 233, 0.28);
  }
</style>
