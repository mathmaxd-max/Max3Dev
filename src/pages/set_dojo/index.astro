---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectGate from '../../components/ProjectGate.astro';
import SetDojoApp from '../../projects/set-dojo/SetDojoApp.astro';
import '../../projects/set-dojo/set-dojo.css';
---

<BaseLayout
  title="Set Dojo — max3.dev"
  description="Set Dojo: Trainer für Set-Erkennung — mobil-first, lokale Einstellungen."
  lang="en"
>
  <ProjectGate>
    <SetDojoApp />
  </ProjectGate>
</BaseLayout>

<script>
  import { isProjectGateActive, PROJECT_GATE_STORAGE_KEY } from '../../lib/project-gate';
  import { mountSetDojo } from '../../projects/set-dojo/set-dojo-client';

  function mount() {
    const root = document.getElementById('set-dojo-root');
    if (root) {
      mountSetDojo(root);
    }
  }

  if (!isProjectGateActive()) {
    mount();
  } else if (typeof sessionStorage !== 'undefined' && sessionStorage.getItem(PROJECT_GATE_STORAGE_KEY) === '1') {
    mount();
  } else {
    document.addEventListener('projectgate-unlocked', mount, { once: true });
  }
</script>
